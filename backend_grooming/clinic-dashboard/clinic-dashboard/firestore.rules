rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /clinics/{clinicId} {
      allow read: if true;
      allow write: if false;
      match /doctors/{doctorId} {
        allow read: if true;
        allow write: if false;
      }
    }

    // Bookings: users create their own, authenticated admins can read & update all
    match /bookings/{bookingId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
      allow delete: if false;
    }

    // Volunteers: anyone can create and read
    match /volunteers/{volunteerId} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if false;
    }

    // Pets: authenticated users can read, shelter admins can write
    match /pets/{petId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Adoptions: authenticated users can read/write
    match /adoptions/{adoptionId} {
      allow read, write: if request.auth != null;
    }

    // Grooming bookings: anyone can create, only authenticated admins can read & update
    match /groomingBookings/{bookingId} {
      allow create: if true;
      allow read, update: if request.auth != null;
      allow delete: if false;
    }

    // IMPORTANT: Required for your web dashboard login to work!
    match /adminRoles/{roleId} {
      allow read: if request.auth != null && request.auth.uid == roleId;
      allow write: if false;
    }
  }
}
