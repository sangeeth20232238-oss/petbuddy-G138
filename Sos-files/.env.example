# ============================================================
#  PET SOS — Backend Environment Variables
#  File: .env  (DO NOT commit this file to version control)
# ============================================================

# Server
PORT=5000
CLIENT_URL=http://localhost:3000

# Firebase Admin SDK
# Paste your full service account JSON as a single-line string
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"your-project-id",...}

# Firebase Storage bucket (from Firebase Console → Storage)
FIREBASE_STORAGE_BUCKET=your-project.appspot.com
