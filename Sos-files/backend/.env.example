# ============================================================
#  PET SOS — Backend Environment Variables
#  Copy this to .env — DO NOT commit .env to version control
# ============================================================

PORT=5000
CLIENT_URL=http://localhost:3000

# Paste your full Firebase service account JSON as ONE line
# Get from: Firebase Console → Project Settings → Service Accounts → Generate new private key
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"your-project-id","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"firebase-adminsdk@your-project.iam.gserviceaccount.com","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token"}

# Firebase Storage bucket (Firebase Console → Storage → copy bucket name)
FIREBASE_STORAGE_BUCKET=your-project.appspot.com
